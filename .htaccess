
# Sécurité maximale pour éditeur HTML/CSS/JS
# Désactive l’exécution de tout code serveur
RemoveHandler .php .phtml .pl .py .cgi .asp .aspx .jsp
RemoveType .php .phtml .pl .py .cgi .asp .aspx .jsp

# Désactive l’exécution de scripts côté client non autorisés
<FilesMatch "\.(php|phtml|pl|py|cgi|asp|aspx|jsp)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Désactive l’indexation des répertoires
Options -Indexes

# Protection XSS, clickjacking, et content sniffing
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "DENY"
Header set X-XSS-Protection "1; mode=block"
Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data:; font-src 'self' https://cdn.jsdelivr.net; object-src 'none'; frame-ancestors 'none'; base-uri 'self';"

# Compression GZIP
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache statique pour les assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# Désactive l’upload et l’exécution de fichiers dangereux
<FilesMatch "\.(exe|sh|bat|msi|dll|com|scr|jar)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Désactive les méthodes HTTP dangereuses
<LimitExcept GET POST HEAD>
  Deny from all
</LimitExcept>

# Désactive le hotlinking des assets
SetEnvIf Referer ".*" local_ref=1
<FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|css|js)$">
  SetEnvIf local_ref 1
  Order Allow,Deny
  Allow from env=local_ref
</FilesMatch>
